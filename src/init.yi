  plist = stdr.str_concat(plist, lt)
  plist = stdr.str_concat(plist, "/plist")
  plist = stdr.str_concat(plist, gt)
  plist = stdr.str_concat(plist, "\n")

  return stdr.write_text_file(plist_path, plist)
